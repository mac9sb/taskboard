# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit real tokens.
#
# mise automatically loads .env for all `mise run` tasks.

# ── Azure ─────────────────────────────────────────────────────────────────────

# Target resource group (created automatically by mise run infra:up)
AZURE_RESOURCE_GROUP=taskboard-rg

# Azure region — pick one close to you:
# eastus, westeurope, australiaeast, uksouth, etc.
AZURE_LOCATION=eastus

# ── GitHub Container Registry ─────────────────────────────────────────────────

# Personal Access Token with read:packages (and write:packages for local builds).
# Create one at: https://github.com/settings/tokens/new?scopes=read:packages,write:packages
GHCR_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
